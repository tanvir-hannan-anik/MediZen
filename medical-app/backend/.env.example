# Copy to .env and fill in your values
ANTHROPIC_API_KEY=your_anthropic_api_key_here
SECRET_KEY=change_this_to_a_random_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Path to the medical PDF (relative to backend/ or absolute)
PDF_PATH=../gale-encyclopedia-of-medicine.-vol.-1.-2nd-ed.pdf

# FAISS index storage directory
VECTOR_STORE_DIR=./vector_store

# Database — PostgreSQL via docker-compose (default)
DATABASE_URL=postgresql+psycopg2://diu_medical:diu_medical_dev_pwd@localhost:5432/diu_medical
# To use SQLite instead (no Docker required):
# DATABASE_URL=sqlite:///./medical_app.db

# Tesseract OCR binary path (Windows example)
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
